# ── AI (build phase: Google Gemini free tier) ─────────────────────────
# Get one at: https://aistudio.google.com/  →  Get API key
GEMINI_API_KEY=

# ── Supabase ──────────────────────────────────────────────────────────
# Project Settings → API: URL, anon (public), service_role (SERVER ONLY)
# Project Settings → Database → Connection string → URI
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# ── Hosting (Vercel) ──────────────────────────────────────────────────
# https://vercel.com/account/tokens → Create Token
# VERCEL_ORG_ID / VERCEL_PROJECT_ID are added after `vercel link`
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# ── Email (Resend) ────────────────────────────────────────────────────
# https://resend.com/api-keys
# For local dev, use the test sender: onboarding@resend.dev
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# ── Monitoring ────────────────────────────────────────────────────────
# Sentry: Project Settings → Client Keys (DSN) — one DSN per project
SENTRY_DSN_BACKEND=
SENTRY_DSN_IOS=
# PostHog: Project Settings → Project API Key (phc_...) + host
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# ── Apple (provided by friend with Apple Developer account) ───────────
# Member details → Team ID
APPLE_TEAM_ID=
APP_BUNDLE_ID=com.medora.app
# APNs Auth Key (.p8 file in ./secrets/)
APNS_KEY_ID=
APNS_AUTH_KEY_PATH=./secrets/AuthKey_APNS.p8
# App Store Connect API Key (.p8 file in ./secrets/)
ASC_KEY_ID=
ASC_ISSUER_ID=
ASC_API_KEY_PATH=./secrets/AuthKey_ASC.p8

# ── Domain (optional) ────────────────────────────────────────────────
APP_DOMAIN=
