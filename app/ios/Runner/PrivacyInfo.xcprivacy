<?xml version="1.0" encoding="UTF-8"?>
<!-- PrivacyInfo.xcprivacy — REQUIRED by Apple for App Store submissions
     since 1 May 2024. Declares the "required reason API" categories
     Concord touches. Most are "NO" today; UserDefaults is the only one
     we actively use (shared_preferences) and the reason is 1A2 (app
     functionality) per Apple's taxonomy. -->

<plist version="1.0">
<dict>
	<key>NSPrivacyTracking</key>
	<false/>
	<key>NSPrivacyTrackingDomains</key>
	<array/>
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>CA92.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>