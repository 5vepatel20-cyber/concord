# Concord app — public env vars (committed).
# Copy to `.env` and fill in real values. `.env` is gitignored.
# Server-only secrets (GEMINI_API_KEY, SUPABASE_SERVICE_ROLE_KEY, etc.) MUST NEVER live in the app.

# ── Supabase (anon key is safe to bundle; RLS enforces access) ──
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...replace-me

# ── Backend API (Vercel) ───────────────────────────────────────
API_BASE_URL=https://concord-backend.vercel.app

# ── Sentry iOS DSN (public; designed to be bundled) ───────────
SENTRY_DSN_IOS=https://YOUR-KEY@oYOUR-ORG.ingest.us.sentry.io/YOUR-PROJECT

# ── PostHog (project API key is public; not the personal key) ─
POSTHOG_API_KEY=phc_replace-me
POSTHOG_HOST=https://us.i.posthog.com
